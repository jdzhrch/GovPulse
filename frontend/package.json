{
  "name": "govpulse-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "check:design": "node scripts/check-editorial-redesign.mjs",
    "check:reports": "node --experimental-strip-types scripts/check-scan-report-associations.ts",
    "check:sorting": "node --experimental-strip-types scripts/check-assessment-sorting.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.294.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
