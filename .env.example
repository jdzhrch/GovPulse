# =============================================================================
# GovPulse Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in the actual values

# -----------------------------------------------------------------------------
# Python Engines (scout_engine.py, impact_analyzer.py)
# -----------------------------------------------------------------------------

# OpenAI API Key - used for GPT-4o compliance analysis
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Frontend (Vite environment variables must start with VITE_)
# -----------------------------------------------------------------------------

# GitHub Personal Access Token - used to trigger GitHub Actions
# Create at: GitHub Settings > Developer settings > Personal access tokens > Tokens (classic)
# Required permissions: repo (Full control of private repositories)
# Create at: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=ghp_your-github-token-here

# GitHub repository owner (username or organization name)
VITE_GITHUB_REPO_OWNER=your-github-username

# GitHub repository name
VITE_GITHUB_REPO_NAME=GovPulse

# -----------------------------------------------------------------------------
# Optional: Search Engine API (used for fetch_real_world_data)
# -----------------------------------------------------------------------------

# Tavily API - AI-optimized search API (recommended)
# Get your key from: https://tavily.com/
# TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Serper API - Google Search API alternative
# Get your key from: https://serper.dev/
# SERPER_API_KEY=your-serper-api-key-here

# -----------------------------------------------------------------------------
# Optional: Notification Integration
# -----------------------------------------------------------------------------

# Slack Webhook URL - used for P0/P1 alert notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# -----------------------------------------------------------------------------
# Development Mode Settings
# -----------------------------------------------------------------------------

# Set to true to use mock data instead of real API
# DEMO_MODE=false
