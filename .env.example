# =============================================================================
# GovPulse 环境变量配置
# Environment Variables Configuration
# =============================================================================
# 复制此文件为 .env 并填入真实值
# Copy this file to .env and fill in the actual values

# -----------------------------------------------------------------------------
# Python Engines (scout_engine.py, impact_analyzer.py)
# -----------------------------------------------------------------------------

# OpenAI API 密钥 - 用于 GPT-4o 合规分析
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Frontend (Vite 环境变量必须以 VITE_ 开头)
# -----------------------------------------------------------------------------

# GitHub Personal Access Token - 用于触发 GitHub Actions
# 创建方法: GitHub Settings > Developer settings > Personal access tokens > Tokens (classic)
# 所需权限: repo (Full control of private repositories)
# Create at: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=ghp_your-github-token-here

# GitHub 仓库所有者 (用户名或组织名)
VITE_GITHUB_REPO_OWNER=your-github-username

# GitHub 仓库名称
VITE_GITHUB_REPO_NAME=GovPulse

# -----------------------------------------------------------------------------
# Optional: 搜索引擎 API (用于 fetch_real_world_data)
# -----------------------------------------------------------------------------

# Tavily API - AI 优化的搜索 API (推荐)
# Get your key from: https://tavily.com/
# TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Serper API - Google 搜索 API 替代方案
# Get your key from: https://serper.dev/
# SERPER_API_KEY=your-serper-api-key-here

# -----------------------------------------------------------------------------
# Optional: 通知集成
# -----------------------------------------------------------------------------

# Slack Webhook URL - 用于 P0/P1 警报推送
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# -----------------------------------------------------------------------------
# 开发模式设置
# -----------------------------------------------------------------------------

# 设为 true 使用模拟数据而非真实 API
# DEMO_MODE=false
